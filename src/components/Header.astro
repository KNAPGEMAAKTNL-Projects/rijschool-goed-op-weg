---
/**
 * Site header — navigation, text logo, phone, CTA, mobile menu.
 * Source: DESIGN.md §5 (nav links), CONTENT/homepage.md Nav section.
 * Phosphor icons (rounded, 2px stroke). Mobile menu via checkbox hack (zero JS).
 */
const navLinks = [
  { label: 'Opleidingen', href: '/opleidingen/autorijles' },
  { label: 'Tarieven', href: '/tarieven' },
  { label: 'Geslaagd', href: '/geslaagd' },
  { label: 'Over ons', href: '/over-ons' },
  { label: 'Contact', href: '/contact' },
];
---
<header class="site-header">
  <nav class="nav-container" aria-label="Hoofdnavigatie">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Rijschool Goed op Weg — Home">
      <span class="logo-text">GOED OP WEG</span>
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links">
      {navLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>

    <!-- Desktop right side: phone + CTA -->
    <div class="nav-right">
      <a href="tel:0628990655" class="nav-phone">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46ZM176,208A128.14,128.14,0,0,1,48,80,40.2,40.2,0,0,1,82.87,40a.61.61,0,0,0,0,.12l21,47L83.2,111.86a6.13,6.13,0,0,0-.57.77,16,16,0,0,0-1,15.7c9.06,18.53,27.73,37.06,46.46,46.11a16,16,0,0,0,15.17-1.4,8.12,8.12,0,0,0,.75-.56L168.89,152l47,21.05h0s.08,0,.11,0A40.21,40.21,0,0,1,176,208Z"/></svg>
        <span>06 28990655</span>
      </a>
      <a href="#contact" class="nav-cta">
        Plan je proefles
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Mobile menu toggle (checkbox hack — zero JS) -->
    <input type="checkbox" id="mobile-menu-toggle" class="mobile-toggle-input" aria-hidden="true" />
    <label for="mobile-menu-toggle" class="mobile-toggle-btn" aria-label="Menu openen">
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"/></svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/></svg>
    </label>

    <!-- Mobile menu overlay -->
    <div class="mobile-menu">
      <ul class="mobile-nav-links">
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
      <a href="#contact" class="mobile-menu-cta">Plan je proefles</a>
      <a href="tel:0628990655" class="mobile-menu-phone">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46ZM176,208A128.14,128.14,0,0,1,48,80,40.2,40.2,0,0,1,82.87,40a.61.61,0,0,0,0,.12l21,47L83.2,111.86a6.13,6.13,0,0,0-.57.77,16,16,0,0,0-1,15.7c9.06,18.53,27.73,37.06,46.46,46.11a16,16,0,0,0,15.17-1.4,8.12,8.12,0,0,0,.75-.56L168.89,152l47,21.05h0s.08,0,.11,0A40.21,40.21,0,0,1,176,208Z"/></svg>
        06 28990655
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
    height: 4rem;
  }

  .nav-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.125rem;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  @media (min-width: 1024px) {
    .nav-links { display: flex; }
  }

  .nav-links a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: color 200ms var(--ease-project);
  }

  @media (hover: hover) {
    .nav-links a:hover { color: var(--color-primary); }
  }

  .nav-right {
    display: none;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }

  @media (min-width: 1024px) {
    .nav-right { display: flex; }
  }

  .nav-phone {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 200ms var(--ease-project);
  }

  @media (hover: hover) {
    .nav-phone:hover { color: var(--color-primary); }
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.25rem;
    background-color: var(--color-primary);
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 300ms var(--ease-project);
  }

  @media (hover: hover) {
    .nav-cta:hover {
      background-color: var(--color-primary-dark);
      color: white;
      transform: translateY(-2px);
    }
  }

  /* Mobile menu toggle */
  .mobile-toggle-input {
    display: none;
  }

  .mobile-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: auto;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
    color: var(--color-text);
  }

  @media (min-width: 1024px) {
    .mobile-toggle-btn { display: none; }
  }

  .icon-close { display: none; }
  .mobile-toggle-input:checked ~ .mobile-toggle-btn .icon-menu { display: none; }
  .mobile-toggle-input:checked ~ .mobile-toggle-btn .icon-close { display: block; }

  /* Mobile menu overlay */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 4rem;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    padding: 2rem 1.5rem;
    flex-direction: column;
    gap: 1.5rem;
    overflow-y: auto;
  }

  .mobile-toggle-input:checked ~ .mobile-menu {
    display: flex;
  }

  .mobile-nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-links a {
    display: block;
    padding: 0.875rem 0;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-menu-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem;
    background-color: var(--color-primary);
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
  }

  .mobile-menu-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }
</style>
