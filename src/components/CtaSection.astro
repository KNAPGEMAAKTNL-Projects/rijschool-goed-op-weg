---
/**
 * Reusable CTA block — used between sections and on subpages.
 * Source: DESIGN.md §12. Dark bg with diagonal top divider.
 *
 * @prop {string} heading - CTA heading text
 * @prop {string} subtext - Supporting text below heading
 * @prop {string} buttonText - Primary CTA button text
 * @prop {string} buttonHref - CTA link target
 * @prop {boolean} showWhatsApp - Show WhatsApp button alongside primary CTA
 */
interface Props {
  heading?: string;
  subtext?: string;
  buttonText?: string;
  buttonHref?: string;
  showWhatsApp?: boolean;
}

const {
  heading = 'Zin in een proefles?',
  subtext = 'Vrijblijvend · Binnen 24 uur reactie',
  buttonText = 'Plan je proefles',
  buttonHref = '/contact',
  showWhatsApp = true,
} = Astro.props;

const waUrl = 'https://wa.me/31628990655?text=' + encodeURIComponent('Hoi! Ik heb interesse in rijles bij Goed op Weg.');
---
<section class="cta-section">
  <div class="cta-inner">
    <h2>{heading}</h2>
    <p class="cta-sub">{subtext}</p>
    <div class="cta-buttons">
      <a href={buttonHref} class="cta-btn-primary">
        {buttonText}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      {showWhatsApp && (
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="cta-btn-wa">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-primary-surface);
    padding: 4rem 0;
  }

  .cta-inner {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .cta-inner h2 {
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 200px;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary);
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 300ms var(--ease-project);
  }

  @media (hover: hover) {
    .cta-btn-primary:hover {
      background-color: var(--color-primary-dark);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 12px 24px -8px rgba(240, 90, 30, 0.3);
    }
  }

  .cta-btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-whatsapp);
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 300ms var(--ease-project);
  }

  @media (hover: hover) {
    .cta-btn-wa:hover {
      background-color: var(--color-whatsapp-hover);
      transform: translateY(-2px);
    }
  }
</style>
