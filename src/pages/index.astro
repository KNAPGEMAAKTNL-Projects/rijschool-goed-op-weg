---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import DiagonalDivider from '../components/DiagonalDivider.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import MobileCta from '../components/MobileCta.astro';
import services from '../data/services.json';

const stats = [
  { value: 91, suffix: '%', label: 'Motor geslaagd', comparison: '+9% boven CBR-gemiddelde' },
  { value: 90, suffix: '%', label: 'Bromfiets geslaagd', comparison: '+3% boven gemiddelde' },
  { value: 100, suffix: '%', label: 'Taxi geslaagd', comparison: '+40% boven gemiddelde' },
];

const faqItems = [
  { q: 'Hoeveel rijlessen heb ik nodig voor mijn rijbewijs?', a: 'Dat verschilt per persoon. Gemiddeld heb je 35 tot 45 lessen nodig voor je autorijbewijs. Na een paar lessen kan ik een betere inschatting geven van wat jij nodig hebt.' },
  { q: 'Kan ik rijles nemen met een automaat?', a: 'Ja, er is een auto met automaat beschikbaar. Je haalt dan een B-rijbewijs voor automaat. Wil je later toch schakelen? Dan kun je altijd een aanvullend examen doen.' },
  { q: 'Hoe oud moet ik zijn om te beginnen met rijles?', a: 'Voor autorijles kun je starten vanaf 16,5 jaar (met 2toDrive) of vanaf 17 jaar regulier. Bromfiets mag vanaf 16 jaar. Motorrijles kan vanaf 20 jaar, of 24 voor onbeperkt vermogen.' },
  { q: 'Wat als ik zak voor mijn examen?', a: 'Dat kan gebeuren, geen stress. Ik plan gewoon extra lessen in en je doet opnieuw examen. De meeste leerlingen slagen de tweede keer wel.' },
  { q: 'Hoe werkt de dagcursus bromfiets?', a: "Je doet theorie en praktijk op dezelfde dag. 's Ochtends beginnen met theorie, daarna oefenen op de weg, en aan het eind van de dag doe je examen bij het CBR in Tiel." },
  { q: 'Hoe plan ik een proefles?', a: 'Stuur gerust een appje via WhatsApp, bel 06 28990655, of vul het formulier hieronder in. Je hoort binnen 24 uur van mij.' },
  { q: 'Moet ik zelf mijn theorie regelen?', a: 'Ja, theorie doe je via een online theorie-app in je eigen tempo. Tijdens de rijlessen bespreken we wel de verkeerssituaties die je tegenkomt op de weg.' },
  { q: 'Geef je ook les buiten Tiel?', a: 'Ja, ik geef ook les in de omgeving. Denk aan Geldermalsen, Culemborg, Buren en de rest van de Betuwe. Het CBR-examen doe je in Tiel (motor voertuigbeheersing in Arnhem).' },
];

/* Placeholder gallery students — replace with real Facebook data */
const students = [
  { name: 'Amin', category: 'Motor', tall: true },
  { name: 'Sinem', category: 'Auto', tall: false },
  { name: 'Youssef', category: 'Bromfiets', tall: false },
  { name: 'Melisa', category: 'Auto', tall: true },
  { name: 'Berk', category: 'Motor', tall: false },
  { name: 'Sara', category: 'Bromfiets', tall: true },
  { name: 'Nabil', category: 'Taxi', tall: false },
  { name: 'Daan', category: 'Auto', tall: false },
  { name: 'Fatima', category: 'Motor', tall: true },
  { name: 'Ayoub', category: 'Bromfiets', tall: false },
  { name: 'Lotte', category: 'Auto', tall: false },
  { name: 'Thomas', category: 'BE', tall: true },
];

const traits = ['Geduldig', 'Ervaren', 'Eerlijk', 'Persoonlijk'];

const pricingCards = [
  {
    title: 'Autorijles',
    price: '€\u00a0XX',
    unit: 'per les',
    features: ['60 minuten per les', 'Haal- en brengservice in Tiel', 'Examenvoorbereiding'],
    cta: 'Plan je proefles',
    ctaStyle: 'outline',
    featured: false,
  },
  {
    title: 'Dagcursus bromfiets',
    price: '€\u00a0XXX',
    unit: 'alles-in',
    features: ['Theorie + praktijk + examen', 'Alles op één dag', 'Geschikt vanaf 16 jaar'],
    cta: 'Boek je dagcursus',
    ctaStyle: 'primary',
    featured: true,
    badge: 'Populair',
  },
  {
    title: 'Motorrijles',
    price: '€\u00a0XX',
    unit: 'per les',
    features: ['AVB + verkeersdeelname', 'Eigen motor beschikbaar', '91% slagingspercentage'],
    cta: 'Plan je proefles',
    ctaStyle: 'outline',
    featured: false,
  },
];
---
<Layout
  title="Rijschool Tiel | 91% Motor Geslaagd | Goed op Weg"
  description="Rijles in Tiel met slagingspercentages ver boven het CBR-gemiddelde. Motor 91%, bromfiets 90%, taxi 100%. Plan je proefles, vrijblijvend."
>
  <Header />

  <main>
    {/* ═══════════════════════════════════════════════════════════
        SECTION 1: HERO — full-bleed dark overlay, left-aligned
        Padding: 0 (full-viewport, min-h: 92vh)
        Background: #1A1A2E with image overlay
    ═══════════════════════════════════════════════════════════ */}
    <section class="hero" id="hero">
      <div class="hero-bg" aria-hidden="true">
        {/* Placeholder — replace with real CBR celebration photo */}
        <div class="hero-bg-placeholder"></div>
      </div>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="hero-content hero-entrance">
        <div class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" class="hero-badge-star"><path d="M234.29,114.85l-45,38.83L203,211.75a16.4,16.4,0,0,1-24.5,17.82L128,198.49,77.47,229.57A16.4,16.4,0,0,1,53,211.75l13.76-58.07-45-38.83A16.46,16.46,0,0,1,31.08,91l59.46-5.15,23.21-55.36a16.4,16.4,0,0,1,30.5,0l23.21,55.36L226.92,91a16.46,16.46,0,0,1,9.37,23.84Z"/></svg>
          <span>5,0/5 &middot; 15 Google Reviews</span>
        </div>

        <h1>Rijles in Tiel? Goed op Weg.</h1>

        <p class="hero-sub">Motor 91% geslaagd, bromfiets 90%, taxi 100%. Ver boven het CBR-gemiddelde. Persoonlijke rijlessen in Tiel en de Betuwe.</p>

        <div class="hero-ctas">
          <a href="#contact" class="btn-primary">
            Plan je proefles
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="https://wa.me/31628990655?text=Hoi!%20Ik%20heb%20interesse%20in%20rijles%20bij%20Goed%20op%20Weg." target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>

        <a href="tel:0628990655" class="hero-phone">06 28990655</a>
        <p class="hero-micro">Vrijblijvend &middot; Binnen 24 uur reactie</p>
      </div>
    </section>

    {/* Diagonal: Hero → Stats */}
    <DiagonalDivider direction="right-down" fill="var(--hex-bg)" />

    {/* ═══════════════════════════════════════════════════════════
        SECTION 2: STATS ROW — CBR slagingspercentages
        Padding: 4rem / 3rem mobile
        Background: #FFFAF7
    ═══════════════════════════════════════════════════════════ */}
    <section class="stats scroll-fade-up" id="stats">
      <div class="stats-container">
        <p class="stats-intro">Rijschool Goed op Weg verzorgt rijlessen voor auto, motor, bromfiets, aanhangwagen en taxi in Tiel en de Betuwe. Eén vaste instructeur begeleidt je persoonlijk tot aan je examen. De slagingspercentages liggen ver boven het CBR-gemiddelde: 91% voor motor, 90% voor bromfiets en 100% voor taxi.</p>
        <div class="stats-grid stagger-container">
          {stats.map((stat) => (
            <div class="stat-card scroll-scale-reveal">
              <span class="stat-number">{stat.value}{stat.suffix}</span>
              <span class="stat-label">{stat.label}</span>
              <span class="stat-comparison">{stat.comparison}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ═══════════════════════════════════════════════════════════
        SECTION 3: OPLEIDINGEN — 3×2 card grid with featured
        Padding: 5rem / 3.5rem mobile
        Background: #FFFFFF
    ═══════════════════════════════════════════════════════════ */}
    <section class="opleidingen scroll-fade-up" id="opleidingen">
      <div class="section-container">
        <h2>Welke opleiding past bij jou?</h2>
        <p class="section-sub">Van je eerste autorijles tot een dagcursus bromfiets. Kies wat bij je past.</p>
        <div class="opl-grid stagger-container">
          {services.map((svc) => (
            <div class:list={['opl-card', { 'opl-card-featured': svc.featured }]}>
              {svc.featured && <span class="populair-badge">Populair</span>}
              <span class="opl-icon" aria-hidden="true">
                {svc.icon === 'car' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M240,112H229.2L201.42,49.5A16,16,0,0,0,186.8,40H69.2a16,16,0,0,0-14.62,9.5L26.8,112H16a8,8,0,0,0,0,16h8v80a16,16,0,0,0,16,16H64a16,16,0,0,0,16-16V192h96v16a16,16,0,0,0,16,16h24a16,16,0,0,0,16-16V128h8a8,8,0,0,0,0-16ZM69.2,56H186.8l24.89,56H44.31ZM64,208H40V192H64Zm128,0V192h24v16Zm24-32H40V128H216ZM56,152a8,8,0,0,1,8-8H80a8,8,0,0,1,0,16H64A8,8,0,0,1,56,152Zm112,0a8,8,0,0,1,8-8h16a8,8,0,0,1,0,16H176A8,8,0,0,1,168,152Z"/></svg>}
                {svc.icon === 'motorcycle' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M216,120a41,41,0,0,0-6.19.47L186,80H208a8,8,0,0,0,0-16H176a8,8,0,0,0-6.91,4L146.46,104H112V96h24a8,8,0,0,0,0-16H88a8,8,0,0,0,0,16h8v8H80.42L70,81.63A8,8,0,0,0,62.8,76.2l-.41,0A48,48,0,1,0,40,168a47.69,47.69,0,0,0,27.2-8.42l22.52,33.78A8,8,0,0,0,96.38,197L97,197a8,8,0,0,0,6.61-3.48L135.1,146a8,8,0,0,0-1.31-10.09L117.47,120h25.34l14.28-24.56L176.41,128A48.07,48.07,0,1,0,216,120ZM40,152a32,32,0,0,1,23.79-30.89L92,163.84A31.84,31.84,0,0,1,40,152Zm56.56,24.68L69.15,133.5a31.93,31.93,0,0,1,11.72-4.48ZM216,152a32,32,0,0,1-24.41-52.56l19.5,39A8,8,0,0,0,225.5,131,32.09,32.09,0,0,1,216,152Z"/></svg>}
                {svc.icon === 'moped' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M216,120a41,41,0,0,0-6.19.47L186,80H208a8,8,0,0,0,0-16H176a8,8,0,0,0-6.91,4l-23,39.55L136,96H88a8,8,0,0,0,0,16h40.37l-16,27.47A48.07,48.07,0,1,0,40,168a47.54,47.54,0,0,0,22.38-5.57L74,180.3A8,8,0,0,0,80.65,184H81a8,8,0,0,0,6.66-3.56l28.85-44.53,38.23,28.17A8,8,0,0,0,162,161L176.41,128A48.07,48.07,0,1,0,216,120ZM40,152a32,32,0,1,1,32-32A32,32,0,0,1,40,152Zm176,0a32,32,0,1,1,32-32A32,32,0,0,1,216,152Z"/></svg>}
                {svc.icon === 'trailer' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M224,96H176V72a8,8,0,0,0-8-8H24A16,16,0,0,0,8,80v96a8,8,0,0,0,8,8H40.29a32,32,0,0,0,63.42,0h48.58a32,32,0,0,0,63.42,0H240a8,8,0,0,0,8-8V120A24,24,0,0,0,224,96ZM160,80v96H152.29a32,32,0,0,0-63.42,0V80Zm-88,96a16,16,0,1,1,16-16A16,16,0,0,1,72,192ZM24,80H88v96H103.71a32,32,0,0,0-31.42,0H24ZM184,192a16,16,0,1,1,16-16A16,16,0,0,1,184,192Zm48-16H215.71a32,32,0,0,0-63.42,0H176V112h48a8,8,0,0,1,8,8Z"/></svg>}
                {svc.icon === 'taxi' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M240,112H229.2L201.42,49.5A16,16,0,0,0,186.8,40H156V24a8,8,0,0,0-8-8H108a8,8,0,0,0-8,8V40H69.2a16,16,0,0,0-14.62,9.5L26.8,112H16a8,8,0,0,0,0,16h8v80a16,16,0,0,0,16,16H64a16,16,0,0,0,16-16V192h96v16a16,16,0,0,0,16,16h24a16,16,0,0,0,16-16V128h8a8,8,0,0,0,0-16ZM116,32h24V40H116ZM69.2,56H186.8l24.89,56H44.31ZM64,208H40V192H64Zm128,0V192h24v16Zm24-32H40V128H216ZM56,152a8,8,0,0,1,8-8H80a8,8,0,0,1,0,16H64A8,8,0,0,1,56,152Zm112,0a8,8,0,0,1,8-8h16a8,8,0,0,1,0,16H176A8,8,0,0,1,168,152Z"/></svg>}
                {svc.icon === 'lightning' && <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M215.79,118.17a8,8,0,0,0-5-5.66L153.18,90.9l14.66-73.33a8,8,0,0,0-13.69-7l-112,120a8,8,0,0,0,3,12.95l57.63,21.61L88.16,238.43a8,8,0,0,0,13.69,7l112-120A8,8,0,0,0,215.79,118.17ZM109.37,214l10.47-52.38a8,8,0,0,0-5-9.06L62,132.71l84.62-90.66L136.16,94.43a8,8,0,0,0,5,9.06l52.8,19.8Z"/></svg>}
              </span>
              <h3 class="opl-title">{svc.title}</h3>
              <p class="opl-body">{svc.body}</p>
              <a href={svc.link} class="opl-link">
                {svc.linkText}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ═══════════════════════════════════════════════════════════
        SECTION 4: USP STRIP
        Padding: 2.5rem / 2rem mobile
        Background: #FFF0E8
    ═══════════════════════════════════════════════════════════ */}
    <section class="usp-strip scroll-fade-up">
      <div class="section-container">
        <div class="usp-grid">
          <div class="usp-item">
            <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M232,128A104,104,0,1,0,128,232,104.12,104.12,0,0,0,232,128Zm-16,0a87.45,87.45,0,0,1-20.41,56.28L147.32,136H216A87.48,87.48,0,0,1,216,128ZM40,128a88.1,88.1,0,0,1,88-88,87.45,87.45,0,0,1,56.28,20.41l-48.27,48.28H40.67A88.51,88.51,0,0,1,40,128Zm88,88a88.1,88.1,0,0,1-88-88,88.51,88.51,0,0,1,.67-10.72l89.33.01L178.28,165.6A87.45,87.45,0,0,1,128,216Z"/></svg>
            <span>Eén vaste instructeur</span>
          </div>
          <div class="usp-item">
            <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M232,208a8,8,0,0,1-8,8H32a8,8,0,0,1-8-8V48a8,8,0,0,1,16,0V156.69l50.34-50.35a8,8,0,0,1,11.32,0L128,132.69,180.69,80H160a8,8,0,0,1,0-16h40a8,8,0,0,1,8,8v40a8,8,0,0,1-16,0V91.31l-58.34,58.35a8,8,0,0,1-11.32,0L96,123.31l-56,56V200H224A8,8,0,0,1,232,208Z"/></svg>
            <span>Ver boven CBR-gemiddelde</span>
          </div>
          <div class="usp-item">
            <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor"><path d="M240,112H229.2L201.42,49.5A16,16,0,0,0,186.8,40H69.2a16,16,0,0,0-14.62,9.5L26.8,112H16a8,8,0,0,0,0,16h8v80a16,16,0,0,0,16,16H64a16,16,0,0,0,16-16V192h96v16a16,16,0,0,0,16,16h24a16,16,0,0,0,16-16V128h8a8,8,0,0,0,0-16ZM69.2,56H186.8l24.89,56H44.31ZM64,208H40V192H64Zm128,0V192h24v16Zm24-32H40V128H216Z"/></svg>
            <span>Schakelen én automaat</span>
          </div>
          <div class="usp-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>Direct via WhatsApp</span>
          </div>
        </div>
      </div>
    </section>

    {/* ═══════════════════════════════════════════════════════════
        SECTION 5: DAGCURSUS — 7/5 asymmetric
        Padding: 6rem / 4rem mobile
        Background: #F9EFEB
    ═══════════════════════════════════════════════════════════ */}
    <section class="dagcursus scroll-fade-up" id="dagcursus">
      <div class="section-container">
        <div class="dagcursus-grid">
          <div class="dagcursus-content">
            <span class="section-label">Populairste opleiding</span>
            <h2>In één dag je bromfietsrijbewijs</h2>
            <p>De dagcursus bromfiets is veruit de populairste opleiding. Logisch, want je hebt in één dag je AM-rijbewijs.</p>
            <p>Je begint 's ochtends met theorie. Daarna oefen je op de bromfiets in het verkeer. Aan het eind van de dag doe je gewoon examen bij het CBR in Tiel. 90% van de leerlingen slaagt in één keer.</p>
            <p>Geschikt vanaf 16 jaar. Ervaring hoeft niet.</p>
            <ul class="check-list">
