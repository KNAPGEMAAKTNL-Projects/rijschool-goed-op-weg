<style>
  /* CSS variables from global.css are available globally — no @reference needed */

  /* ── Layout helpers ────────────────────────────────────── */
  .section-container {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .section-sub {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    margin-top: 2rem;
    transition: gap 300ms var(--ease-project);
  }
  @media (hover: hover) {
    .section-link:hover { gap: 0.625rem; }
  }

  .text-white { color: white; }
  .text-white-60 { color: rgba(255, 255, 255, 0.6); }
  .text-white-40 { color: rgba(255, 255, 255, 0.4); }

  /* ── BTN ─────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 200px;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-primary);
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
    border: none;
    transition: all 300ms var(--ease-project);
  }
  @media (hover: hover) {
    .btn-primary:hover {
      background-color: var(--color-primary-dark);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 12px 24px -8px rgba(240, 90, 30, 0.3);
    }
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-whatsapp);
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 300ms var(--ease-project);
  }
  @media (hover: hover) {
    .btn-whatsapp:hover {
      background-color: var(--color-whatsapp-hover);
      transform: translateY(-2px);
    }
  }

  .cta-micro {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  /* ═══════════════ SECTION 1: HERO ═══════════════════════ */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: 4rem; /* nav height */
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-dark);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 26, 46, 0.92) 0%,
      rgba(26, 26, 46, 0.5) 60%,
      rgba(26, 26, 46, 0.3) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 35rem;
    padding: 4rem 1.5rem 6rem;
    margin-left: max(1.5rem, calc((100% - 68.75rem) / 2));
  }

  @media (max-width: 767px) {
    .hero-content { padding: 3rem 1.5rem 4rem; margin-left: 0; }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 100px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8125rem;
    color: white;
    margin-bottom: 1.25rem;
