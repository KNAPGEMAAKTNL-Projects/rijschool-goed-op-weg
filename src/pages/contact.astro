---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---
<Layout
  title="Contact | Rijschool Goed op Weg Tiel"
  description="Neem contact op met Rijschool Goed op Weg in Tiel. Stuur een appje, bel 06 28990655, of plan je proefles via het formulier. Binnen 24 uur reactie."
>
  <Header />
  <main>
    <!-- Page heading -->
    <section class="page-hero-light">
      <div class="page-hero-inner">
        <h1>Laten we kennismaken</h1>
        <p class="page-hero-sub">
          Stuur gerust een appje, bel, of vul het formulier in. Je hoort binnen 24 uur van mij. Dan plannen we samen je eerste les.
        </p>
      </div>
    </section>

    <!-- Contact form + info grid -->
    <section class="contact-section">
      <div class="contact-inner">
        <div class="contact-grid">
          <!-- 7/12 — Form -->
          <div class="contact-form-col">
            <h2>Plan je proefles</h2>
            <p class="form-subtext">Vrijblijvend &middot; Binnen 24 uur reactie</p>
            <ContactForm />
          </div>

          <!-- 5/12 — Contact info -->
          <div class="contact-info-col">
            <!-- WhatsApp -->
            <a href="https://wa.me/31628990655" target="_blank" rel="noopener noreferrer" class="wa-button">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Stuur een bericht
            </a>

            <!-- Phone -->
            <div class="info-block">
              <h3>Bel [Voornaam]</h3>
              <a href="tel:+31628990655" class="info-link">06 28990655</a>
            </div>

            <!-- Email -->
            <div class="info-block">
              <h3>E-mail</h3>
              <a href="mailto:info@rijschoolgoedopweg.nl" class="info-link">info@rijschoolgoedopweg.nl</a>
            </div>

            <!-- Address -->
            <div class="info-block">
              <h3>Adres</h3>
              <p>Gildehof 18<br />4002 HG Tiel</p>
            </div>

            <!-- Opening hours -->
            <div class="info-block">
              <h3>Openingstijden</h3>
              <p>Op afspraak. Neem contact op om een moment te plannen dat jou uitkomt.</p>
            </div>

            <!-- Credentials -->
            <div class="info-credentials">
              <span>KvK: 51173336</span>
              <span>Rijschoolnummer: 7633G1</span>
            </div>

            <!-- Map placeholder -->
            <div class="map-placeholder" aria-label="Google Maps: Gildehof 18, 4002 HG Tiel">
              <svg width="32" height="32" viewBox="0 0 256 256" fill="currentColor" opacity="0.3"><path d="M128,16a88.1,88.1,0,0,0-88,88c0,75.3,80,132.17,83.41,134.55a8,8,0,0,0,9.18,0C136,236.17,216,179.3,216,104A88.1,88.1,0,0,0,128,16Zm0,56a32,32,0,1,1-32,32A32,32,0,0,1,128,72Z"/></svg>
              <span>Google Maps — Gildehof 18, Tiel</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ── Page hero light ──────────────────────────────── */
  .page-hero-light {
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: 8rem 0 4rem;
  }
  .page-hero-inner {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .page-hero-light h1 {
    margin-bottom: 1rem;
  }
  .page-hero-sub {
    font-size: 1.125rem;
    max-width: 38rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* ── Contact section (dark bg) ────────────────────── */
  .contact-section {
    background-color: var(--color-dark);
    padding: 4rem 0 5rem;
  }
  .contact-inner {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 3rem;
    align-items: start;
  }

  /* Form column */
  .contact-form-col h2 {
    color: white;
    margin-bottom: 0.375rem;
  }
  .form-subtext {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  /* Info column */
  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* WhatsApp button */
  .wa-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-whatsapp);
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 300ms var(--ease-project);
    align-self: flex-start;
  }
  @media (hover: hover) {
    .wa-button:hover {
      background-color: var(--color-whatsapp-hover);
      transform: translateY(-2px);
    }
  }

  /* Info blocks */
  .info-block h3 {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.375rem;
  }
  .info-block p {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0;
  }
  .info-link {
    color: white;
    text-decoration: none;
    font-weight: 500;
    transition: color 300ms var(--ease-project);
  }
  @media (hover: hover) {
    .info-link:hover {
      color: var(--color-primary);
    }
  }

  /* Credentials */
  .info-credentials {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .info-credentials span {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
  }

  /* Map placeholder */
  .map-placeholder {
    aspect-ratio: 16 / 9;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8125rem;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .page-hero-light {
      padding: 6rem 0 3rem;
    }
  }
</style>
