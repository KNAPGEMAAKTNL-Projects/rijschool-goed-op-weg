---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pagina niet gevonden — Rijschool Goed op Weg">
  <main class="flex min-h-[60vh] items-center justify-center">
    <div class="text-center">
      <h1 class="text-primary">404</h1>
      <p class="mt-4 text-lg text-text-muted">Deze pagina bestaat niet.</p>
      <a href="/" class="mt-8 inline-block rounded-[8px] bg-primary px-6 py-3 font-heading font-bold text-dark transition-all duration-300 hover:bg-primary-dark hover:text-white hover:-translate-y-0.5">
        Terug naar home
      </a>
    </div>
  </main>
</Layout>
